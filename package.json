{
  "name": "@bjornharrtell/json-api",
  "version": "6.2.0",
  "type": "module",
  "main": "./dist/lib.mjs",
  "module": "./dist/lib.mjs",
  "types": "./dist/lib.d.mts",
  "exports": {
    ".": "./dist/lib.mjs",
    "./*": "./src/*"
  },
  "files": ["README.md", "dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjornharrtell/json-api.git"
  },
  "scripts": {
    "dev": "tsdown src/lib.ts --format esm --dts --sourcemap --minify --watch",
    "test": "vitest",
    "test:integration": "vitest run tests/integration/jsonapi-dotnetcore.spec.ts",
    "test:coverage": "vitest run --coverage",
    "test:integration:coverage": "vitest run --coverage tests/integration/jsonapi-dotnetcore.spec.ts",
    "coverage": "vitest run --coverage",
    "coveralls": "pnpm run coverage && cat ./coverage/lcov.info | coveralls",
    "build": "tsdown src/lib.ts --format esm --dts --sourcemap --minify --clean",
    "type-check": "tsc --noEmit",
    "typedoc": "typedoc"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^25.9.5",
    "@vitest/coverage-v8": "^4.1.10",
    "coveralls": "^3.1.1",
    "tsdown": "^0.22.8",
    "typedoc": "^0.28.20",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
